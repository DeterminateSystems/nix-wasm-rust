{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "cargo",
			"command": "build",
			"args": [
				"--release",
				"--workspace",
				"--exclude",
				"nix-wasm-plugin-quickjs",
				"--exclude",
				"nix-wasm-plugin-fib-wasi"
			],
			"options": {
				"env": {
					"CARGO_BUILD_TARGET": "wasm32-unknown-unknown"
				}
			},
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "rust: cargo build"
		}
	]
}